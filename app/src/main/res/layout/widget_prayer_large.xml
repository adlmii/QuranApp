<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <!-- ═══ TOP SECTION: Main prayer card ═══ -->
    <LinearLayout
        android:id="@+id/header_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_highlight_bg"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Left: Prayer info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_widget_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SHOLAT BERIKUTNYA"
                android:textColor="#80CBC4"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_widget_prayer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maghrib"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tv_widget_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Jakarta"
                android:textColor="#5DA89B"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Right: Time + Countdown -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tv_widget_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18:05"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_widget_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1j 23m lagi"
                android:textColor="#E8C55A"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ BOTTOM SECTION: All 5 prayer times ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header_section"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Subuh -->
        <LinearLayout
            android:id="@+id/pill_fajr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_prayer_pill"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginEnd="4dp">
            <TextView
                android:id="@+id/tv_fajr_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subuh"
                android:textColor="#80CBC4"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/tv_fajr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="04:35"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Dzuhur -->
        <LinearLayout
            android:id="@+id/pill_dhuhr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_prayer_pill"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginEnd="4dp">
            <TextView
                android:id="@+id/tv_dhuhr_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dzuhur"
                android:textColor="#80CBC4"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/tv_dhuhr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11:55"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Ashar -->
        <LinearLayout
            android:id="@+id/pill_asr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_prayer_pill"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginEnd="4dp">
            <TextView
                android:id="@+id/tv_asr_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ashar"
                android:textColor="#80CBC4"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/tv_asr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15:10"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Maghrib -->
        <LinearLayout
            android:id="@+id/pill_maghrib"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_prayer_pill"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginEnd="4dp">
            <TextView
                android:id="@+id/tv_maghrib_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maghrib"
                android:textColor="#80CBC4"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/tv_maghrib_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18:05"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Isya -->
        <LinearLayout
            android:id="@+id/pill_isha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_prayer_pill"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">
            <TextView
                android:id="@+id/tv_isha_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Isya"
                android:textColor="#80CBC4"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/tv_isha_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="19:15"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
